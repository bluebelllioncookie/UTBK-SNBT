import React, { useMemo, useState } from "react";
import { motion } from "framer-motion";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";

const flashcards = [
  { subject: "TPS", q: "Apa fungsi utama TPS?", a: "Mengukur penalaran, logika, dan kesiapan akademik." },
  { subject: "TKA Matematika", q: "Turunan x² adalah?", a: "2x" },
  { subject: "Literasi", q: "Ide pokok paragraf adalah?", a: "Gagasan utama yang menjadi inti paragraf." },
];

const weakTopics = ["Penalaran Matematika", "TKA Biologi", "Literasi Bahasa Inggris"];
const demoQuestionBank = {
  tps: [
    {
      id: 1,
      title: "Jika semua dokter adalah pembelajar...",
      answer: "B",
      explanation: "Ini silogisme. Kalau semua dokter pembelajar, dan Dita dokter, maka Dita pembelajar.",
    },
    {
      id: 2,
      title: "Nilai x pada 2x + 6 = 20",
      answer: "C",
      explanation: "Pindahkan 6 ke kanan: 2x = 14, jadi x = 7.",
    },
  ],
  tka_biologi: [
    {
      id: 1,
      title: "Organel penghasil energi sel adalah...",
      answer: "A",
      explanation: "Mitokondria sering disebut pembangkit energi sel karena menghasilkan ATP.",
    },
  ],
  tka_kimia: [
    {
      id: 1,
      title: "Jumlah mol pada 18 gram H2O adalah...",
      answer: "B",
      explanation: "Mr H2O = 18, maka 18/18 = 1 mol.",
    },
  ],
};

const subjects = [
  ["Penalaran Umum", "Basic → Advanced", "Sedang"],
  ["Pengetahuan Kuantitatif", "Basic → Advanced", "Sulit"],
  ["TKA Matematika", "Basic → Advanced", "Sulit"],
  ["TKA Biologi", "Basic → Advanced", "Sedang"],
  ["TKA Kimia", "Basic → Advanced", "Sulit"],
  ["TKA Fisika", "Basic → Advanced", "Sulit"],
];

// FULLSTACK PRODUCTION SETUP
// Frontend: Next.js (App Router) + React + Tailwind
// Backend API routes:
// - /api/auth/register
// - /api/auth/login
// - /api/chat
// - /api/questions
// - /api/tryout
// - /api/leaderboard
// Database: PostgreSQL / Supabase
// Main tables:
// users(id, name, email, password_hash)
// questions(id, subject, prompt, choices, answer, explanation, difficulty)
// attempts(id, user_id, question_id, selected_answer, correct)
// tryouts(id, user_id, score, percentile)
// rankings(id, user_id, score, updated_at)
// Security:
// bcrypt password hashing
// httpOnly auth cookies
// CSRF protection
// rate limiting
// row-level security

export default function UTBKUltimateApp() {
  const [premiumMode] = useState(true);
  const [flipped, setFlipped] = useState<number | null>(null);
  const [saved, setSaved] = useState<number[]>([]);
  const [tab, setTab] = useState("dashboard");
  const [aiQuestion, setAiQuestion] = useState("");
  const [aiAnswer, setAiAnswer] = useState("Coba tanya konsep UTBK apa pun. Contoh: gimana cara cepat ngerjain silogisme?");
  const [user, setUser] = useState(() => {
    if (typeof window !== "undefined") {
      return JSON.parse(localStorage.getItem("utbk-user") || "null");
    }
    return null;
  });

  const [progress, setProgress] = useState(() => {
    if (typeof window !== "undefined") {
      return JSON.parse(localStorage.getItem("utbk-progress") || '{"solved":34,"streak":14,"savedFlashcards":2}');
    }
    return { solved: 34, streak: 14, savedFlashcards: 2 };
  });

  const todayTarget = useMemo(() => ({ questions: 45, quiz: 8 }), []);

  const askAI = async () => {
    if (!aiQuestion.trim()) return;

    // Production backend example:
    // const res = await fetch('/api/chat', { method:'POST', body: JSON.stringify({ message: aiQuestion }) })
    // const data = await res.json()

    setAiAnswer(
      "Bayangin gini: silogisme itu kayak rantai logika. Kalau semua dokter suka belajar, dan Rani itu dokter, berarti Rani suka belajar. Di UTBK, jangan langsung lihat kata sulitnya — cukup cek apakah kesimpulan mengikuti premis."
    );
  };

  const loginDemo = () => {
    const demoUser = {
      name: "Di",
      targetCampus: "UI",
      major: "Kedokteran",
    };
    setUser(demoUser);
    if (typeof window !== "undefined") localStorage.setItem("utbk-user", JSON.stringify(demoUser));
  };

  const saveProgress = (next) => {
    setProgress(next);
    if (typeof window !== "undefined") localStorage.setItem("utbk-progress", JSON.stringify(next));
  };

  return (
    <div className="min-h-screen bg-slate-950 text-white p-4 md:p-8">
      <div className="max-w-7xl mx-auto space-y-6">
        <header className="rounded-[2rem] p-8 bg-gradient-to-r from-indigo-600 via-violet-600 to-cyan-600 shadow-2xl relative overflow-hidden">
          <div className="absolute right-6 top-6 rounded-full px-4 py-2 bg-white/10 backdrop-blur text-xs uppercase tracking-[0.2em]">
            {premiumMode ? "Premium" : "Basic"}
          </div>
          <p className="uppercase tracking-[0.25em] text-sm opacity-90">UTBK / SNBT Master Hub</p>
          <h1 className="text-4xl md:text-6xl font-bold mt-2">Belajar Adaptif Sampai Lolos PTN</h1>
          <p className="mt-3 max-w-3xl text-base md:text-lg opacity-95">
            AI tutor aktif, tracker kampus, analisis kelemahan, bank soal ratusan subtes, TKA, rewind materi, mini quiz harian, dan onboarding kecocokan belajar.
          </p>
        </header>

        {!user && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <h2 className="text-2xl font-semibold">Login Belajar</h2>
                <p className="text-slate-400 mt-2">Masuk agar progres, target kampus, dan hasil tryout tersimpan otomatis.</p>
              </div>
              <Button onClick={loginDemo} className="rounded-2xl">Masuk Demo User</Button>
            </CardContent>
          </Card>
        )}

        {user && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-5 flex flex-wrap gap-6 items-center justify-between">
              <div>
                <p className="text-sm text-slate-400">Login sebagai</p>
                <p className="text-xl font-semibold">{user.name}</p>
              </div>
              <div className="text-sm text-slate-300">Target: {user.targetCampus} — {user.major}</div>
              <div className="text-sm text-slate-300">Soal selesai: {progress.solved}</div>
            </CardContent>
          </Card>
        )}

        <section className="grid md:grid-cols-4 gap-4">
          {[
            ["Akurasi 30 hari", "87%"],
            ["Database soal", `${Object.values(demoQuestionBank).reduce((a,b)=>a+b.length,0)} soal`],
            ["Bank soal", "1,250+"],
            ["Materi video ringkas", "220+"],
            ["Prediksi lolos", "Kedokteran UI 41%"],
          ].map(([title, value]) => (
            <Card key={title} className="bg-slate-900 border-slate-800 rounded-3xl">
              <CardContent className="p-5">
                <p className="text-sm text-slate-400">{title}</p>
                <p className="text-2xl font-bold mt-2">{value}</p>
              </CardContent>
            </Card>
          ))}
        </section>

        <div className="flex gap-2 overflow-x-auto pb-2">
          {["dashboard", "materi", "flashcards", "ai", "kampus", "infografis", "tryout", "progres", "planner", "intensif", "admin"].map((item) => (
            <Button key={item} variant={tab === item ? "default" : "secondary"} onClick={() => setTab(item)}>
              {item}
            </Button>
          ))}
        </div>

        {tab === "dashboard" && (
          <div className="space-y-6">
            <section className="grid md:grid-cols-4 gap-4">
              {[
                ["Target soal hari ini", `${todayTarget.questions} soal`],
                ["Mini quiz harian", `${todayTarget.quiz} soal`],
                ["Streak belajar", "14 hari"],
                ["Prediksi kesiapan", "82%"],
              ].map(([title, value]) => (
                <Card key={title} className="bg-slate-900 border-slate-800 rounded-3xl">
                  <CardContent className="p-5">
                    <p className="text-sm text-slate-400">{title}</p>
                    <p className="text-3xl font-bold mt-2">{value}</p>
                  </CardContent>
                </Card>
              ))}
            </section>

            <section className="grid lg:grid-cols-3 gap-6">
              <Card className="lg:col-span-2 bg-slate-900 border-slate-800 rounded-3xl">
                <CardContent className="p-6">
                  <h2 className="text-2xl font-semibold">Onboarding Tes Kecocokan Belajar</h2>
                  <p className="text-slate-400 mt-2">Analisis target, kelemahan, ritme belajar, dan rekomendasi jurusan/kampus.</p>
                  <div className="grid md:grid-cols-2 gap-3 mt-4">
                    <Input placeholder="Target PTN (contoh: UI)" className="bg-slate-950 border-slate-700" />
                    <Input placeholder="Jurusan impian" className="bg-slate-950 border-slate-700" />
                    <Input placeholder="Subtes tersulit" className="bg-slate-950 border-slate-700" />
                    <Button className="rounded-2xl">Mulai Analisis</Button>
                  </div>
                </CardContent>
              </Card>

              <Card className="bg-slate-900 border-slate-800 rounded-3xl">
                <CardContent className="p-6">
                  <h2 className="text-2xl font-semibold">Pengingat Belajar</h2>
                  <div className="space-y-3 mt-4 text-sm">
                    {["07.00 Flashcards", "16.30 Mini Quiz", "20.00 Rewind Materi Lupa"].map((x) => (
                      <div key={x} className="rounded-2xl bg-slate-950 border border-slate-800 p-3">{x}</div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </section>

            <section className="grid lg:grid-cols-2 gap-6">
              <Card className="bg-slate-900 border-slate-800 rounded-3xl">
                <CardContent className="p-6">
                  <h2 className="text-2xl font-semibold">Kita Lemah di Materi Apa?</h2>
                  <div className="mt-4 space-y-3">
                    {weakTopics.map((x) => (
                      <div key={x} className="rounded-2xl bg-slate-950 border border-slate-800 p-3">{x}</div>
                    ))}
                  </div>
                </CardContent>
              </Card>

              <Card className="bg-slate-900 border-slate-800 rounded-3xl">
                <CardContent className="p-6">
                  <h2 className="text-2xl font-semibold">Tracker Kampus per Jurusan</h2>
                  <div className="space-y-3 mt-4 text-sm">
                    {[
                      "Universitas Indonesia — Kedokteran",
                      "Institut Teknologi Bandung — Teknik Biomedis",
                      "Universitas Gadjah Mada — Kedokteran",
                    ].map((x) => (
                      <div key={x} className="rounded-2xl bg-slate-950 border border-slate-800 p-3">{x}</div>
                    ))}
                  </div>
                </CardContent>
              </Card>
            </section>
          </div>
        )}

        {tab === "materi" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Materi Lengkap + Rewind Materi</h2>
              <p className="text-slate-400 mt-2">UTBK, SNBT, dan TKA dari basic sampai advanced.</p>
              <div className="grid md:grid-cols-2 xl:grid-cols-3 gap-4 mt-5">
                {subjects.map(([title, level, diff]) => (
                  <div key={title} className="rounded-2xl bg-slate-950 p-4 border border-slate-800">
                    <h3 className="font-semibold">{title}</h3>
                    <p className="text-sm text-slate-400 mt-2">{level}</p>
                    <p className="text-sm text-slate-400">Kesulitan: {diff}</p>
                    <div className="flex gap-2 mt-4">
                      <Button size="sm">Materi</Button>
                      <Button size="sm" variant="secondary">Latihan</Button>
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "flashcards" && (
          <div className="grid md:grid-cols-3 gap-5">
            {flashcards.map((card, i) => (
              <motion.div key={i} whileHover={{ y: -4 }}>
                <Card
                  className="bg-slate-900 border-slate-800 rounded-3xl cursor-pointer h-full"
                  onClick={() => setFlipped(flipped === i ? null : i)}
                >
                  <CardContent className="p-6">
                    <p className="text-sm text-slate-400">{card.subject}</p>
                    <h3 className="text-xl font-semibold mt-3">{flipped === i ? card.a : card.q}</h3>
                    <Button
                      className="mt-4"
                      variant={saved.includes(i) ? "secondary" : "default"}
                      onClick={(e) => {
                        e.stopPropagation();
                        setSaved((prev) => (prev.includes(i) ? prev.filter((x) => x !== i) : [...prev, i]));
                      }}
                    >
                      {saved.includes(i) ? "Tersimpan" : "Simpan"}
                    </Button>
                  </CardContent>
                </Card>
              </motion.div>
            ))}
          </div>
        )}

        {tab === "ai" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6 space-y-4">
              <h2 className="text-2xl font-semibold">AI Tutor Aktif 24/7</h2>
              <p className="text-slate-400">Dirancang menjelaskan seperti teman sebaya: ringkas, akurat, dan pakai permisalan.</p>
              <div className="rounded-2xl bg-slate-950 border border-slate-800 p-4 text-sm leading-7">
                {aiAnswer}
              </div>
              <div className="flex gap-3">
                <Input value={aiQuestion} onChange={(e) => setAiQuestion(e.target.value)} placeholder="Contoh: cara cepat ngerjain penalaran kuantitatif" className="bg-slate-950 border-slate-700" />
                <Button onClick={askAI}>Tanya</Button>
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "tryout" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Tryout Premium Adaptif</h2>
              <div className="grid md:grid-cols-3 gap-4 mt-4 mb-2">
                {[
                  ["Skor terbaru", "712"],
                  ["Ranking nasional", "#184"],
                  ["Peluang Kedokteran UI", "43%"],
                ].map(([a,b]) => (
                  <div key={a} className="rounded-2xl bg-slate-950 border border-slate-800 p-4">
                    <p className="text-sm text-slate-400">{a}</p>
                    <p className="text-xl font-semibold mt-2">{b}</p>
                  </div>
                ))}
              </div>
              <p className="text-slate-400 mt-2">Sistem menyesuaikan tingkat kesulitan berdasarkan performa subtes terakhir.</p>
              <div className="grid md:grid-cols-3 gap-4 mt-5">
                {[
                  ["TPS Lengkap", "60 soal · 90 menit"],
                  ["TKA Saintek", "45 soal · 75 menit"],
                  ["Mini Drill Harian", "10 soal · 12 menit"],
                ].map(([title, meta]) => (
                  <div key={title} className="rounded-2xl bg-slate-950 border border-slate-800 p-4">
                    <h3 className="font-semibold">{title}</h3>
                    <p className="text-sm text-slate-400 mt-2">{meta}</p>
                    <Button className="mt-4">Mulai</Button>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "progres" && (
          <div className="space-y-6">
            <Card className="bg-slate-900 border-slate-800 rounded-3xl">
              <CardContent className="p-6">
                <h2 className="text-2xl font-semibold">Database Soal Besar + Pembahasan</h2>
                <div className="grid md:grid-cols-2 xl:grid-cols-3 gap-4 mt-5">
                  {Object.entries(demoQuestionBank).map(([key, arr]) => (
                    <div key={key} className="rounded-2xl bg-slate-950 border border-slate-800 p-4">
                      <h3 className="font-semibold">{key.replace(/_/g, " ")}</h3>
                      <p className="text-sm text-slate-400 mt-2">{arr.length} soal tersedia</p>
                      {arr[0] && <p className="text-xs text-slate-500 mt-2">Pembahasan: {arr[0].explanation}</p>}
                      <Button className="mt-4" size="sm" onClick={() => saveProgress({ ...progress, solved: progress.solved + 5 })}>
                        Kerjakan 5 soal
                      </Button>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Progres Belajar Premium</h2>
              <p className="text-slate-400 mt-2">Prediksi kampus berdasarkan skor: UI Kedokteran, ITB Sains Hayati, UGM Kedokteran.</p>
              <div className="space-y-4 mt-5">
                {[
                  ["Penalaran Umum", "78%"],
                  ["Pengetahuan Kuantitatif", "61%"],
                  ["TKA Biologi", "72%"],
                  ["TKA Kimia", "54%"],
                ].map(([name, score]) => (
                  <div key={name} className="rounded-2xl bg-slate-950 border border-slate-800 p-4">
                    <div className="flex items-center justify-between">
                      <span>{name}</span>
                      <span className="text-sm text-slate-400">{score}</span>
                    </div>
                    <div className="mt-3 h-2 rounded-full bg-slate-800 overflow-hidden">
                      <div className="h-full bg-white/70" style={{ width: score }} />
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "planner" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Planner Alternatif Setelah UTBK</h2>
              <p className="text-slate-400 mt-2">Jalur cadangan strategis kalau target utama belum tercapai.</p>
              <div className="grid md:grid-cols-3 gap-4 mt-5">
                {[
                  ["Poltekkes", "Fokus saintek + latihan biologis intensif"],
                  ["Sekolah Kedinasan", "TPS, wawasan kebangsaan, matematika dasar"],
                  ["Ujian Mandiri PTN", "Drill soal kampus target + manajemen waktu"],
                ].map(([title, desc]) => (
                  <div key={title} className="rounded-2xl bg-slate-950 border border-slate-800 p-4">
                    <h3 className="font-semibold">{title}</h3>
                    <p className="text-sm text-slate-400 mt-2">{desc}</p>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "intensif" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Latihan Soal Intensif</h2>
              <p className="text-slate-400 mt-2">Program 14 hari menjelang ujian dengan target progres harian.</p>
              <div className="space-y-3 mt-5">
                {[
                  "Hari 1–4: TPS dasar 50 soal/hari + review kesalahan",
                  "Hari 5–8: Literasi + TKA campuran 65 soal/hari",
                  "Hari 9–12: Tryout adaptif + pembahasan detail",
                  "Hari 13–14: Rewind materi lemah + mini quiz cepat",
                ].map((x) => (
                  <div key={x} className="rounded-2xl bg-slate-950 border border-slate-800 p-3">{x}</div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "admin" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Admin Panel Soal</h2>
              <p className="text-slate-400 mt-2">Input/edit soal, pembahasan, kategori subtes, dan validasi kualitas soal.</p>
              <div className="grid md:grid-cols-2 gap-4 mt-5">
                <Input placeholder="Judul soal" className="bg-slate-950 border-slate-700" />
                <Input placeholder="Subtes (TPS/TKA)" className="bg-slate-950 border-slate-700" />
                <Input placeholder="Jawaban benar" className="bg-slate-950 border-slate-700" />
                <Button className="rounded-2xl">Simpan Soal</Button>
              </div>
            </CardContent>
          </Card>
        )}

        {tab === "infografis" && (
          <Card className="bg-slate-900 border-slate-800 rounded-3xl">
            <CardContent className="p-6">
              <h2 className="text-2xl font-semibold">Ringkasan Materi Infografis</h2>
              <div className="grid md:grid-cols-3 gap-4 mt-5">
                {["TKA Biologi: Sistem Sel", "TPS: Penalaran Induktif", "TKA Kimia: Stoikiometri"].map((x) => (
                  <div key={x} className="rounded-2xl bg-gradient-to-br from-violet-600 to-indigo-700 p-5 min-h-36">
                    <h3 className="font-semibold">{x}</h3>
                    <p className="text-sm mt-3 opacity-95">Ringkasan visual cepat untuk review sebelum latihan soal.</p>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
